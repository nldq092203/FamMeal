# ============================================================
# FamMeal — Global environment for Docker Compose
# Loaded automatically by `docker compose` from project root.
# ============================================================

# ----- PostgreSQL (docker-compose service) ------------------
POSTGRES_USER=fammeal
POSTGRES_PASSWORD=changeme_pg_password
POSTGRES_DB=fammeal

# ----- Backend (Fastify API) --------------------------------
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Internal Docker network URLs (preferred for compose)
DATABASE_URL=postgresql://fammeal:changeme_pg_password@postgres:5432/fammeal
REDIS_URL=redis://redis:6379
CACHE_DEFAULT_TTL_SECONDS=60

# CORS (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,http://localhost:3000

# JWT secrets (generated local values; rotate for shared/prod envs)
JWT_ACCESS_SECRET=a9d06c8b374f65a0fb1280ddcda62115abe6388733184d805a15cc9daf189936979087b7f5e82cb40c0d65930ef14f46d5ae06b3961ee608d68528ba4437bb7c
JWT_REFRESH_SECRET=959ab35cbe49b4973aaf92954ab934cbe425bfb0e7680623026e144f7181e6f4cd724488c61e21a74b555f8e88fdb3d609eb9436334131a06d10596b1d4ca408
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info
# LOG_FILE=

# Cron
CRON_ENABLED=false
CRON_SECRET=39ff37d07da5dfa3061a9edfe4fc74b53d91a0b65a1a3236

# ----- Frontend (Vite) --------------------------------------
# For dev override this remains localhost:3000/api.
VITE_API_BASE_URL=http://localhost:3000/api

# ----- Optional external service overrides -------------------
# Uncomment and replace if you want to use external services:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# REDIS_URL=rediss://default:PASSWORD@HOST:PORT
